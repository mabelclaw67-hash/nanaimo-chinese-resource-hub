# .env.local — Local development environment variables
# Copy this file to .env.local and fill in the values.
# This file is read by local-dev-server.mjs.
# Do NOT commit .env.local to git (it contains private URLs).

# Paste the Google Apps Script web app URL for Service Providers.
# Find it in: Netlify dashboard → bb884e8f site → Site settings → Environment variables
# Variable name: GOOGLE_SERVICE_PROVIDERS_SCRIPT_URL
GOOGLE_SERVICE_PROVIDERS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec

# Optional fallback (used if GOOGLE_SERVICE_PROVIDERS_SCRIPT_URL is not set):
# GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec
